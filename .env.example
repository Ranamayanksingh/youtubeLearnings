# Copy this file to .env and fill in your values
# cp .env.example .env

# -------------------------------------------------------------------
# LLM Provider — set to "claude" or "gemini"
# -------------------------------------------------------------------
LLM_PROVIDER=claude

# Claude (Anthropic) — required when LLM_PROVIDER=claude
ANTHROPIC_API_KEY=your-anthropic-api-key-here
CLAUDE_MODEL=claude-sonnet-4-6

# Gemini (Google) — required when LLM_PROVIDER=gemini
# GEMINI_API_KEY=your-gemini-api-key-here
# GEMINI_MODEL=gemini-2.0-flash

# Groq — required when LLM_PROVIDER=groq
# Get your key at: console.groq.com
# GROQ_API_KEY=your-groq-api-key-here
# GROQ_MODEL=llama-3.3-70b-versatile
# For vision: GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# -------------------------------------------------------------------
# Whisper transcription model
# Options: tiny | base | small | medium | large-v3  (default: small)
# -------------------------------------------------------------------
# WHISPER_MODEL=small

# -------------------------------------------------------------------
# HuggingFace token — required for speaker diarization (meeting mode)
# Get yours at: huggingface.co/settings/tokens
# Accept model license at: hf.co/pyannote/speaker-diarization-3.1
# -------------------------------------------------------------------
HF_TOKEN=your-hf-token-here
