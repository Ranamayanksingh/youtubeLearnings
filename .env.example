# Copy this file to .env and fill in your values
# cp .env.example .env

ANTHROPIC_API_KEY=your-api-key-here

# Required if config.yaml sets llm.provider: "gemini"
# GEMINI_API_KEY=your-gemini-api-key-here

# Optional: override default Whisper model (tiny/base/small/medium/large-v3)
# WHISPER_MODEL=small

# HuggingFace token — required for speaker diarization in meeting analysis
# Get yours at: huggingface.co/settings/tokens
# Also accept model licenses at: hf.co/pyannote/speaker-diarization-3.1
HF_TOKEN=your-hf-token-here
